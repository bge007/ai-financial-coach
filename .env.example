# LLM provider — OpenRouter (OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4.5

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Qdrant
QDRANT_URL=http://localhost:6333

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/coach.db

# App
SECRET_KEY=change-me
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# Dev-only: skip login and auto-authenticate a fixed demo user.
# Set false to use the pre-login landing with email/password signup & login.
# NEVER set true in production.
AUTH_DISABLED=false
